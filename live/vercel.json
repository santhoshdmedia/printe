{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.printe.in/api/:path*"
    },
    {
      "source": "/product/:path*",
      "destination": "https://api.printe.in/product/:path*"
    },
     {
      "source": "/product/:id",
      "destination": "https://api.printe.in/product/:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}